# AI Providers - Server Only
DATA_DIR="/data"

# Railway private Storage Bucket - Server Only
# In production, connect these with Railway reference variables. Never expose them as NEXT_PUBLIC_*.
STORAGE_BUCKET_NAME=""
STORAGE_BUCKET_ACCESS_KEY_ID=""
STORAGE_BUCKET_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_REGION=""
STORAGE_BUCKET_ENDPOINT=""
# Optional. If omitted, the app selects the first configured external provider in this order:
# gemini, openrouter, groq, huggingface, cloudflare.
AI_PROVIDER=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-70b-versatile"
HUGGINGFACE_API_KEY=""
HUGGINGFACE_MODEL="mistralai/Mixtral-8x7B-Instruct-v0.1"
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_AI_MODEL="@cf/meta/llama-3.1-8b-instruct"

# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin - Server Only
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_WEB_API_KEY=""

# Auth Session - Server Only
# Required: generate at least 32 random bytes, for example `openssl rand -hex 32`.
# Use a different value for local development and each deployed environment.
AUTH_SESSION_SECRET=""
# Independent 32+ character HMAC secret for one-time Kakao/Naver OAuth state.
AUTH_OAUTH_STATE_SECRET=""
# Independent 32+ character HMAC secret. Rotating it invalidates existing coupon hashes.
COUPON_HASH_SECRET=""
ADMIN_EMAILS="kara111131@naver.com"

# Authenticator, device pairing, and revenue cryptography - Server Only
# Independent 32-byte random value for encrypting TOTP secrets.
AUTH_TOTP_ENCRYPTION_KEY=""
# Server-only independent secret hashing authenticator digests, minimum 32 bytes. Never prefix with NEXT_PUBLIC_.
AUTH_SECURITY_HASH_KEY=""
# Independent 32-byte random value for signing MFA challenges.
AUTH_MFA_CHALLENGE_SECRET=""
# Independent 32-byte random value for hashing device pairing tokens.
DEVICE_PAIRING_HASH_SECRET=""
# Independent 32-byte random value for encrypting revenue data.
REVENUE_DATA_ENCRYPTION_KEY=""

# Companion App/Universal Links - Server Only
# Android package and Play signing SHA-256 fingerprint (colon-separated, 32 pairs) for /.well-known/assetlinks.json.
ANDROID_APP_PACKAGE="kr.co.dreamwish.companion"
ANDROID_APP_SHA256_CERT_FINGERPRINT=""
# Apple Developer Team ID and app bundle ID for /.well-known/apple-app-site-association.
APPLE_TEAM_ID=""
APPLE_BUNDLE_ID="kr.co.dreamwish.companion"

# Member login OAuth - Server Only (do not prefix with NEXT_PUBLIC_)
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="https://dreamwish.co.kr/api/auth/oauth/kakao/callback"
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_REDIRECT_URI="https://dreamwish.co.kr/api/auth/oauth/naver/callback"

PRIVACY_LOCAL_ONLY=false
ALLOW_EXTERNAL_AI=TRUE
SHOW_EXTERNAL_AI_WARNING=true

GITHUB_TOKEN=""

# Public app base URL
# Local: NEXT_PUBLIC_APP_URL=http://localhost:3000
# Railway: NEXT_PUBLIC_APP_URL=https://dreamwish.co.kr
NEXT_PUBLIC_APP_URL="https://dreamwish.co.kr"
APP_URL=""

# Polar Billing - Server Only
POLAR_ACCESS_TOKEN=""
POLAR_PRODUCT_ID=""
POLAR_WEBHOOK_SECRET=""
POLAR_SERVER="production"

# OAuth Integrations - Server Only
# Use a different 32+ byte random value in every deployed environment.
INTEGRATION_TOKEN_ENCRYPTION_KEY=""
OAUTH_TOKEN_ENCRYPTION_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://dreamwish.co.kr/api/integrations/google/callback"
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="https://dreamwish.co.kr/api/integrations/slack/callback"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="https://dreamwish.co.kr/api/integrations/github/callback"
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""
NOTION_REDIRECT_URI="https://dreamwish.co.kr/api/integrations/notion/callback"
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="https://dreamwish.co.kr/api/integrations/discord/callback"

# Google tags - Public
# GA4 example: NEXT_PUBLIC_GA_MEASUREMENT_ID="G-PKW99058QE"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GOOGLE_ADS_ID=""

# Manual AdSense unit shown only on the signed-out public home
NEXT_PUBLIC_ADSENSE_SLOT_ID="3983195777"

# Encrypts user-supplied automation API keys at rest (use a 32+ byte random value).
# Direct credentials select keys in this order:
# AUTOMATION_CREDENTIAL_ENCRYPTION_KEY, INTEGRATION_TOKEN_ENCRYPTION_KEY,
# OAUTH_TOKEN_ENCRYPTION_KEY. Production fails closed if all three are empty.
AUTOMATION_CREDENTIAL_ENCRYPTION_KEY=""
