require Pod::Executable.execute_command('node', ['-p', 'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})', __dir__]).strip
platform :ios, '15.1'
prepare_react_native_project!

target 'DREAMWISHCompanion' do
  config = use_native_modules!
  use_react_native!(:path => config[:reactNativePath], :app_path => "#{Pod::Config.instance.installation_root}/..")
  target 'ShareExtension' do
    inherit! :search_paths
  end
  post_install { |installer| react_native_post_install(installer, config[:reactNativePath], :mac_catalyst_enabled => false) }
end
